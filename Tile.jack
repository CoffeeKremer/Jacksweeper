class Tile {
    // Type should be in range (inclusive) of 0-9
    // 9 being a mine, and the rest being the surounding mines.
    field int type;
    field boolean sel, flagged, uncovered;

    constructor Tile new() {
        return this;
    }

    method void flipFlag() {
        if (uncovered = false) {
            let flagged = ~flagged;
        }
        else {
            let flagged = false;
        }
        return;
    }

    method void flipSel() {
        let sel = ~sel;
        return;
    }

    method void uncoverTile() {
        let uncovered = true;
        return;
    }

    method void incType() {
        let type = type + 1;
        return;
    }

    method void setType(int val) {
        let type = val;
        return;
    }

    method int getType() {
        return type;
    }

    function void pokeCursor(int location) {
        var int memAddress;
        let memAddress = 16384+location;
        // column 0
        do Memory.poke(memAddress +64, 252);
        do Memory.poke(memAddress +96, 252);
        do Memory.poke(memAddress +128, 12);
        do Memory.poke(memAddress +160, 12);
        do Memory.poke(memAddress +192, 12);
        do Memory.poke(memAddress +224, 12);
        do Memory.poke(memAddress +736, 12);
        do Memory.poke(memAddress +768, 12);
        do Memory.poke(memAddress +800, 12);
        do Memory.poke(memAddress +832, 12);
        do Memory.poke(memAddress +864, 252);
        do Memory.poke(memAddress +896, 252);
        // column 1
        do Memory.poke(memAddress +65, 4032);
        do Memory.poke(memAddress +97, 4032);
        do Memory.poke(memAddress +129, 3072);
        do Memory.poke(memAddress +161, 3072);
        do Memory.poke(memAddress +193, 3072);
        do Memory.poke(memAddress +225, 3072);
        do Memory.poke(memAddress +737, 3072);
        do Memory.poke(memAddress +769, 3072);
        do Memory.poke(memAddress +801, 3072);
        do Memory.poke(memAddress +833, 3072);
        do Memory.poke(memAddress +865, 4032);
        do Memory.poke(memAddress +897, 4032);
        return;
    }

    function void pokeBorder(int location) {
        var int memAddress;
        let memAddress = 16384+location;
