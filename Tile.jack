        do Memory.poke(memAddress +737, -16384);
        do Memory.poke(memAddress +769, -16384);
        do Memory.poke(memAddress +801, -16384);
        do Memory.poke(memAddress +833, -16384);
        do Memory.poke(memAddress +865, -16384);
        do Memory.poke(memAddress +897, -16384);
        do Memory.poke(memAddress +929, -16384);
        do Memory.poke(memAddress +961, -1);
        do Memory.poke(memAddress +993, -1);
        return;
    }

